# RDF2Fabric Environment Configuration
# Copy this file to .env.local and fill in your values

# Entra ID App Registration
# Create an app registration in Azure Portal > Entra ID > App registrations
# Required settings:
#   - Redirect URI: http://localhost:5173 (for web), msal://{clientId}/auth (for Electron)
#   - Enable "Allow public client flows" for device code flow
#   - API Permissions: Power BI Service > Dataset.ReadWrite.All, User.Read
VITE_MSAL_CLIENT_ID=your-client-id-here

# Optional: Specific tenant (default: 'common' = any Microsoft account)
# VITE_MSAL_TENANT_ID=your-tenant-id-here
